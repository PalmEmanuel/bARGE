{
    "comments": {
        "lineComment": "//",
        "blockComment": [
            "/*",
            "*/"
        ]
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ]
    ],
    "autoClosingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ]
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*(\\{[^}\"']*|\\([^)\"']*|\\[[^\\]\"']*)$",
        "decreaseIndentPattern": "^\\s*(\\}|\\)|\\])"
    },
    "onEnterRules": [
        {
            "beforeText": "^[a-zA-Z_][a-zA-Z0-9_]*\\s*$",
            "action": {
                "indentAction": "None",
                "appendText": "| "
            }
        },
        {
            "beforeText": "^\\|\\s+\\w+.*$",
            "action": {
                "indentAction": "None",
                "appendText": "| "
            }
        }
    ]
}